# Google Sheets Integration
# To set up:
# 1. Create a Google Sheet
# 2. Go to Extensions > Apps Script
# 3. Copy the script from src/app/api/rsvp/route.ts
# 4. Deploy as web app
# 5. Paste the URL below

GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbztc3usouQ5R5MUk90fwThwDp3WWXUS8gETWeEhgmAi5ukQFUqaZGzkK6MQOe3csa8u/exec